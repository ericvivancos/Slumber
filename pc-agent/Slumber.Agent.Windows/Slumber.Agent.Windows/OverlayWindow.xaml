<Window x:Class="Slumber.Agent.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Slumber.Agent.Windows"
        mc:Ignorable="d"
        Title="Slumber Alert"
        Height="220"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#FF1E1E1E">
    <Border CornerRadius="16" Padding="24" Background="#FF1E1E1E">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="¿Sigues despierto?"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <TextBlock x:Name="CountdownText"
                       Text="Pausando en 15 segundos..."
                       FontSize="16"
                       Foreground="#FFD0D0D0"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <Button x:Name="ContinueButton"
                    Content="Seguir viendo"
                    Width="180"
                    Height="46"
                    HorizontalAlignment="Center"
                    Click="ContinueButton_Click"/>
        </StackPanel>
    </Border>
</Window>